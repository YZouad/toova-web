# Copy to `.env.local` for local development (never commit `.env.local`).

# Trellis mesh generation — local dev only.
# Vite proxies /api/trellis/generate → ${TRELLIS_UPSTREAM_ORIGIN}/generate
TRELLIS_UPSTREAM_ORIGIN=http://YOUR_TRELLIS_HOST:8000

# Optional: skip the dev proxy and call Trellis (or an HTTPS BFF) directly.
# VITE_TRELLIS_GENERATE_URL=https://your-bff.example.com/api/trellis/generate

# Optional: GitHub Pages base path when testing a production build locally.
# VITE_BASE_PATH=/toova-web/
